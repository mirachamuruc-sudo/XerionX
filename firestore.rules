rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Default catch-all safety net
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'mirachamuruc@gmail.com' ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true)
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Users Collection rules
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isSignedIn() && isValidId(userId) && isOwner(userId) &&
                    incoming().email is string && incoming().username is string;
      allow update: if (isOwner(userId) || isAdmin()) && (
        isAdmin() || (
          // Protect Admin field modifications for self-escalation
          (!incoming().keys().hasAny(['isAdmin']) || incoming().isAdmin == existing().isAdmin) &&
          incoming().email == existing().email
        )
      );
      allow delete: if isAdmin();
    }

    // Teams Collection rules
    match /teams/{teamId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidId(teamId);
      allow update: if isSignedIn();
      allow delete: if isAdmin() || (isSignedIn() && existing().ownerId == request.auth.uid);
    }

    // Chats Collection rules
    match /chats/{chatId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && isValidId(chatId) && incoming().userId == request.auth.uid;
      allow update: if isSignedIn() && (existing().userId == request.auth.uid || isAdmin());
      allow delete: if isSignedIn() && (existing().userId == request.auth.uid || isAdmin());
    }

    // Transactions Collection rules
    match /transactions/{txId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && isValidId(txId) && (incoming().userId == request.auth.uid || isAdmin());
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // Webhooks Collection rules
    match /webhooks/{webhookId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn();
      allow delete: if isAdmin();
    }

    // WebhookLogs Collection rules
    match /webhookLogs/{logId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidId(logId);
      allow update, delete: if isAdmin();
    }
  }
}
